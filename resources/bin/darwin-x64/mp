#!/bin/bash
# mp — MoonPay CLI wrapper for SimOffice (macOS)
# Runs @moonpay/cli via Electron's Node.js runtime (no system node required).
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RESOURCES_DIR="$(dirname "$SCRIPT_DIR")"
APP_MACOS="$RESOURCES_DIR/../MacOS/SimOffice"
MOONPAY_CLI="$RESOURCES_DIR/moonpay-cli/node_modules/@moonpay/cli/dist/index.js"
exec env ELECTRON_RUN_AS_NODE=1 \
  "$APP_MACOS" \
  -e "delete process.versions.electron;process.execArgv=[];require(process.argv[1]);" \
  "$MOONPAY_CLI" \
  "$@"
